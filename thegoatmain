<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Start • Games & Proxies</title>
  <style>
    :root {
      --bg: #0f0f0f;
      --card: #1a1a1a;
      --accent: #00ff9d;
      --text: #e0e0e0;
      --text-muted: #888;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      background-image: 
        linear-gradient(rgba(0, 255, 157, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 157, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
    }

    header {
      padding: 1.5rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #222;
    }

    .logo {
      font-size: 2rem;
      font-weight: 800;
      background: linear-gradient(90deg, #00ff9d, #00cc7a);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .search-bar {
      width: 400px;
      padding: 12px 20px;
      background: var(--card);
      border: 1px solid #333;
      border-radius: 50px;
      color: white;
      font-size: 1rem;
    }

    .tabs {
      display: flex;
      gap: 2px;
      margin: 2rem 5% 1rem;
    }

    .tab {
      padding: 12px 32px;
      background: var(--card);
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      border-radius: 12px 12px 0 0;
      font-weight: 600;
      transition: all 0.3s;
    }

    .tab.active {
      background: var(--accent);
      color: black;
    }

    .main-content {
      padding: 0 5% 5%;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 20px;
    }

    .card {
      background: var(--card);
      border-radius: 16px;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
      border: 1px solid #222;
    }

    .card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 255, 157, 0.15);
    }

    .card img {
      width: 100%;
      height: 140px;
      object-fit: cover;
    }

    .card-info {
      padding: 16px;
    }

    .card-title {
      font-size: 1.1rem;
      margin-bottom: 6px;
    }

    .card-desc {
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    .section-title {
      font-size: 1.5rem;
      margin: 2.5rem 0 1.5rem;
      color: var(--accent);
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">NEXUS</div>
    <input type="text" class="search-bar" placeholder="Search games or proxies..." id="searchInput">
  </header>

  <div class="tabs">
    <button class="tab active" onclick="switchTab(0)">Games</button>
    <button class="tab" onclick="switchTab(1)">Proxies</button>
  </div>

  <!-- Games Section -->
  <div class="main-content" id="gamesSection">
    <h2 class="section-title">Popular Games</h2>
    <div class="grid" id="gamesGrid">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- Proxies Section -->
  <div class="main-content" id="proxiesSection" style="display: none;">
    <h2 class="section-title">Proxies</h2>
    <div class="grid" id="proxiesGrid">
      <!-- Populated by JS -->
    </div>
  </div>

  <footer>
    Made with ❤️ • <span id="currentTime"></span>
  </footer>

  <script>
    // Sample Games
    const games = [
      { name: "Slope", img: "https://picsum.photos/id/1015/300/200", url: "https://example.com/slope" },
      { name: "2048", img: "https://picsum.photos/id/237/300/200", url: "https://example.com/2048" },
      { name: "Geometry Dash", img: "https://picsum.photos/id/201/300/200", url: "#" },
      { name: "Cookie Clicker", img: "https://picsum.photos/id/180/300/200", url: "#" },
      { name: "Retro Bowl", img: "https://picsum.photos/id/251/300/200", url: "#" },
      { name: "Minecraft (Proxy)", img: "https://picsum.photos/id/180/300/200", url: "#" },
      { name: "Drive Mad", img: "https://picsum.photos/id/1074/300/200", url: "#" },
      { name: "Tetris", img: "https://picsum.photos/id/201/300/200", url: "#" }
    ];

    // Sample Proxies
    const proxies = [
      { name: "Ultraviolet", img: "https://picsum.photos/id/201/300/200", url: "https://uv.example.com" },
      { name: "Rammerhead", img: "https://picsum.photos/id/237/300/200", url: "https://rammerhead.example.com" },
      { name: "Dynamic", img: "https://picsum.photos/id/1015/300/200", url: "https://dynamic.example.com" },
      { name: "Neon Proxy", img: "https://picsum.photos/id/180/300/200", url: "#" },
      { name: "Titanium", img: "https://picsum.photos/id/251/300/200", url: "#" }
    ];

    function createCard(item) {
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <img src="${item.img}" alt="${item.name}">
        <div class="card-info">
          <div class="card-title">${item.name}</div>
          <div class="card-desc">Click to play / use</div>
        </div>
      `;
      card.onclick = () => window.open(item.url, '_blank');
      return card;
    }

    // Populate Grids
    function populateGrids() {
      const gamesGrid = document.getElementById('gamesGrid');
      const proxiesGrid = document.getElementById('proxiesGrid');

      games.forEach(game => gamesGrid.appendChild(createCard(game)));
      proxies.forEach(proxy => proxiesGrid.appendChild(createCard(proxy)));
    }

    // Tab Switching
    function switchTab(tab) {
      document.querySelectorAll('.tab').forEach((t, i) => {
        t.classList.toggle('active', i === tab);
      });

      document.getElementById('gamesSection').style.display = tab === 0 ? 'block' : 'none';
      document.getElementById('proxiesSection').style.display = tab === 1 ? 'block' : 'none';
    }

    // Search Functionality
    document.getElementById('searchInput').addEventListener('input', function(e) {
      const term = e.target.value.toLowerCase();
      
      document.querySelectorAll('.card').forEach(card => {
        const title = card.querySelector('.card-title').textContent.toLowerCase();
        card.style.display = title.includes(term) ? 'block' : 'none';
      });
    });

    // Live Clock
    function updateTime() {
      const timeEl = document.getElementById('currentTime');
      setInterval(() => {
        timeEl.textContent = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
      }, 1000);
    }

    // Initialize
    window.onload = () => {
      populateGrids();
      updateTime();
    };
  </script>
</body>
</html>
